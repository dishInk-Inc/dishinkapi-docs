  "keyFeatures": [
    "Point-of-Sale (POS) with ZRA Smart Invoice compliance",
    "Kitchen Display System (KDS) with real-time order sync",
    "Waiter App for digital floor-side ordering",
    "Table Management with live floor plan",
    "QR Code Digital Menu & hosted restaurant website",
    "WhatsApp Online Ordering (no app required)",
    "Recipe-based Inventory & Food Cost tracking",
    "HRM, Payroll & Staff Attendance automation",
    "Analytics Hub (revenue, menu, kitchen, staff)",
    "Three-layer Offline Mode (Cloud / LAN / Local Storage)",
    "Multi-location management dashboard",
    "Split billing and multiple payment methods (MTN MoMo, Airtel Money, cash, card)"
  ],
  "publicApiSurface": [
    "Management Portal login (email + password)",
    "Staff PIN Login",
    "QR code per-table menu links (dishink.com/r/{restaurant})",
    "WhatsApp ordering shareable menu URL",
    "Booking platform integration (paste URL — Dineplan, OpenTable, SevenRooms, etc.)",
    "Customer order tracking page (via QR on receipt)",
    "Customer-facing Order Board (KFC-style display)",
    "CSV export for analytics and payroll reports",
    "PDF pay slip generation",
    "AI Menu Extraction (PDF/photo upload)",
    "AI Image Import (Pexels/Pixabay)"
  ]
